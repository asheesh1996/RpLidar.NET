<?xml version="1.0" encoding="utf-8" ?>
<!--
  SignPath Artifact Configuration for RpLidar.NET
  ─────────────────────────────────────────────────
  This file is the source of truth for the artifact configuration
  that must be created in the SignPath dashboard:

    Organization > Projects > rplidar-net
      > Artifact Configurations > nuget-sign

  What it does:
    1. Unwraps the GitHub Actions ZIP wrapper (GitHub zips all uploaded artifacts)
    2. Finds the .nupkg inside
    3. Authenticode-signs all .dll and .exe files inside the package
    4. Applies a NuGet publisher signature to the .nupkg itself

  The NuGet publisher signature is what NuGet.org displays as "Signed" and
  what `dotnet nuget verify` checks. The Authenticode signatures on the DLLs
  are what Windows SmartScreen and enterprise policies check at runtime.
-->
<artifact-configuration xmlns="http://signpath.io/artifact-configuration/v1">

  <!-- GitHub Actions wraps all uploaded artifacts in a ZIP file.
       SignPath must unwrap this outer ZIP first. -->
  <zip-file>

    <!-- The NuGet package itself (also a ZIP internally) -->
    <nupkg-file path="*.nupkg">

      <!-- Step 1: Authenticode-sign all managed assemblies inside the package -->
      <pe-file-set>
        <include path="**/*.dll" max-matches="unbounded" />
        <include path="**/*.exe" max-matches="unbounded" min-matches="0" />
        <for-each>
          <authenticode-sign />
        </for-each>
      </pe-file-set>

      <!-- Step 2: Apply a NuGet publisher signature to the package itself.
           This is what NuGet.org validates and displays as a trusted package.
           Requires a publicly-trusted CA certificate (SignPath Foundation
           provides this via their certificate chain). -->
      <nuget-sign />

    </nupkg-file>
  </zip-file>

</artifact-configuration>
